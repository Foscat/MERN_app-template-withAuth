{
  "name": "mern_app-template-withauth-modern",
  "version": "1.3.0",
  "description": "Modernized MERN app template with JWT auth (access + refresh tokens), roles, and Vite/RSuite v5 frontend",
  "main": "server.js",
  "scripts": {
    "start": "if-env NODE_ENV=production && npm run start:prod || npm run start:dev",
    "start:prod": "node server.js",
    "start:dev": "concurrently \"nodemon --ignore 'client/*'\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "heroku-postbuild": "npm run build",
    "docs:api": "jsdoc2md --files \"server.js\" \"app/**/*.js\" \"client/src/api/**/*.js\" > docs/api-reference.md",
    "docs:client": "jsdoc2md --files \"client/src/**/*.{js,jsx}\" > docs/client-components.md",
    "docs:all": "npm run docs:api && npm run docs:client",
    "test:unit": "npm --prefix client run test:unit",
    "test:snapshots": "npm --prefix client run test:snapshots",
    "test:snapshots:verify": "npm --prefix client run test:snapshots:verify",
    "test:snapshots:update": "npm --prefix client run test:snapshots:update"
  },
  "author": "Foscat",
  "license": "ISC",
  "engines": {
    "node": "22.19.0"
  },
  "dependencies": {
    "bcrypt": "latest",
    "cookie-parser": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "if-env": "latest",
    "jsonwebtoken": "latest",
    "minimist": "latest",
    "moment": "latest",
    "mongoose": "latest"
  },
  "devDependencies": {
    "concurrently": "latest",
    "jsdoc-to-markdown": "latest",
    "nodemon": "latest"
  }
}
